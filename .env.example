# system timezone
# TZ identifier: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/Montreal

# Tailscale
# Get your auth key from https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-client-xxxxxx?ephemeral=false
TS_DOMAIN=ancon-cobia.ts.net

# storage volumes
TS_IMMICH_DATA=tailscale-immich-data
IMMICH_UPLOADS=immich-uploads
IMMICH_DB_DATA=immich-postgres-data

# immich env
IMMICH_DB_USERNAME=postgres
IMMICH_DB_DATABASE_NAME=immich

# Mealie

# Immich OAuth
IMMICH_OAUTH_CLIENT_ID=immich

