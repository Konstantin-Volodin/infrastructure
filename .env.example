# ===== system =====
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/Montreal
# host machine IP for Pi-hole DNS wildcard (e.g. 192.168.1.100)
HOST_IP=
DOMAIN=voxlab.home

# ===== storage paths (resolved to absolute by start-services.sh) =====
IMMICH_UPLOADS=./data/immich-uploads
IMMICH_DB_DATA=./data/immich-postgres
MEALIE_DATA=./data/mealie

# ===== immich =====
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_HOSTNAME=database
REDIS_HOSTNAME=redis

# ===== media / downloads =====
DOWNLOADS_PATH=./data/downloads
QBITTORRENT_CONFIG=./data/qbittorrent
PROWLARR_CONFIG=./data/prowlarr

# ===== books (shelfmark + calibre-web) =====
BOOKS_PATH=./data/books
BOOKS_INGEST=./data/cwa-books-ingest
SHELFMARK_CONFIG=./data/shelfmark
CALIBREWEB_CONFIG=./data/calibre-web

# ===== VPN (protonvpn via gluetun) =====
# OpenVPN credentials from account.protonvpn.com/account#openvpn
PROTONVPN_OPENVPN_USER=
PROTONVPN_OPENVPN_PASSWORD=
VPN_SERVER_COUNTRIES=Canada
# set to "on" if using a free plan
PROTONVPN_FREE_ONLY=off

# ===== auto-generated secrets =====
# IMMICH_DB_PASSWORD=
# AUTHELIA_JWT_PASSWORD=
# AUTHELIA_SESSION_SECRET=
# AUTHELIA_STORAGE_ENCRYPTION_KEY=
# AUTHELIA_OIDC_HMAC_SECRET=
