# ===== system =====
TIMEZONE=America/Montreal # https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
HOST_IP=                 # host machine IP for Pi-hole DNS wildcard (e.g. 192.168.1.100)
DOMAIN=voxlab.home

# ===== storage paths =====
IMMICH_UPLOADS=./data/uploads
IMMICH_DB_DATA=./data/postgres
MEALIE_DATA=./data/mealie

# ===== immich =====
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_HOSTNAME=database
REDIS_HOSTNAME=redis

# ===== media / downloads =====
DOWNLOADS_PATH=./data/downloads
QBITTORRENT_CONFIG=./data/qbittorrent
PROWLARR_CONFIG=./data/prowlarr

# ===== VPN (protonvpn via gluetun) =====
PROTONVPN_OPENVPN_USER=       # ProtonVPN OpenVPN/IKEv2 username (from account.protonvpn.com/account#openvpn)
PROTONVPN_OPENVPN_PASSWORD=   # ProtonVPN OpenVPN/IKEv2 password
VPN_SERVER_COUNTRIES=Canada
PROTONVPN_FREE_ONLY=off       # set to "on" if using a free plan

# ===== auto-generated secrets =====
# IMMICH_DB_PASSWORD=
# AUTHELIA_JWT_PASSWORD=
# AUTHELIA_SESSION_SECRET=
# AUTHELIA_STORAGE_ENCRYPTION_KEY=
# AUTHELIA_OIDC_HMAC_SECRET=
